{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kealanmemory.local/schemas/skill_frontmatter.schema.json",
  "title": "KealanMemory skill markdown frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "category",
    "description",
    "triggers",
    "roles",
    "default_files"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/id"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "triggers": {
      "$ref": "#/$defs/stringList"
    },
    "roles": {
      "$ref": "#/$defs/idList"
    },
    "default_files": {
      "$ref": "#/$defs/pathList"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$"
    },
    "idList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "pathList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
