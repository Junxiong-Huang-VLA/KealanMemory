{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kealanmemory.local/schemas/memory_map.schema.json",
  "title": "KealanMemory memory_map.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "root",
    "default_load",
    "project_load",
    "optional_load",
    "on_demand_only",
    "projects",
    "history_index",
    "output_file"
  ],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "root": {
      "type": "string",
      "minLength": 1
    },
    "default_load": {
      "$ref": "#/$defs/pathList"
    },
    "project_load": {
      "$ref": "#/$defs/projectPathList"
    },
    "optional_load": {
      "$ref": "#/$defs/pathList"
    },
    "on_demand_only": {
      "$ref": "#/$defs/pathList"
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "not": {
          "pattern": "[\\\\/]"
        }
      }
    },
    "history_index": {
      "$ref": "#/$defs/relativePath"
    },
    "output_file": {
      "$ref": "#/$defs/relativePath"
    }
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          {
            "pattern": "^[A-Za-z]:"
          },
          {
            "pattern": "^/"
          },
          {
            "pattern": "\\.\\."
          }
        ]
      }
    },
    "pathList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relativePath"
      }
    },
    "projectPathList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "allOf": [
          {
            "$ref": "#/$defs/relativePath"
          },
          {
            "pattern": "\\{project\\}"
          }
        ]
      }
    }
  }
}
